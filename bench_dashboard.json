        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(wlatencyp99{}>0) by (scheduling_group_name) / 1000",
          "legendFormat": "__auto",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Read Throughput by Scheduling Group",
      "description": "Coordinator read ops/s per scheduling group.\n\nscylla_storage_proxy_coordinator_read_latency_count",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
